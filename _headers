# Ensure HTML + service worker are never sticky-cached after a main deploy.
# (Cloudflare / compatible static hosts; ignored elsewhere.)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

/
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

/manifest.json
  Cache-Control: no-cache, must-revalidate
